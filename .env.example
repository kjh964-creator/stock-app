# 이 파일을 .env 로 복사한 뒤 실제 키 값으로 채우세요.
# .env 파일은 절대 깃에 올리지 마세요. (.gitignore 등록 필수)

# === 필수 ===
# Claude API 키 — https://console.anthropic.com/ 에서 발급
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# === 선택: 더 좋은 뉴스 수집을 위해 ===
# 네이버 검색 API (뉴스 검색용) — https://developers.naver.com/apps
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# DART 공시 API (한국 기업 공시) — https://opendart.fss.or.kr/
DART_API_KEY=

# === 선택: 알림 ===
# 텔레그램 봇 (이벤트 알림) — @BotFather 에서 생성
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
